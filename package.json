{
  "name": "bga.wayfarers",
  "version": "1.0.0",
  "description": "",
  "main": "modules/js/Game.js",
  "scripts": {
    "build:ts": "rollup -c",
    "build:scss": "sass --no-source-map src/css/Game.scss wayfarers.css",
    "watch:ts": "rollup -c -w",
    "watch:scss": "sass --watch src/css/Game.scss wayfarers.css",
    "watch": "npm run watch:ts && npm run watch:scss",
    "build": "npm run build:ts && npm run build:scss && npm run genmat",
    "genmat": "php8.4 misc/other/genmat.php misc/*.csv",
    "tests": "APP_GAMEMODULE_PATH=~/git/bga-sharedcode/misc/ phpunit --display-deprecations --display-warnings --bootstrap ./modules/php/Tests/_autoload.php  --colors=always modules/php/Tests"
  },
  "author": "Alena Laskavaia",
  "license": "EPL2.0",
  "devDependencies": {
    "@prettier/plugin-php": "^0.22",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chai": "^4.x.x",
    "@types/mocha": "^10.0.10",
    "@types/node": "^10.9.2",
    "@types/sinon": "^10.x.x",
    "chai": "^4.x.x",
    "jsdom": "^20.0.0",
    "mocha": "^10.x.x",
    "prettier": "^3.6",
    "rollup": "^4.60.0",
    "sass": "^1.32.6",
    "sinon": "^15.x.x",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "plugins": [
      "@prettier/plugin-php"
    ],
    "braceStyle": "1tbs",
    "printWidth": 140,
    "trailingComma": "none"
  }
}
